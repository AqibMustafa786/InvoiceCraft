
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CHECK AUTH
    function isSignedIn() {
      return request.auth != null;
    }

    // CHECK ROLE
    function hasRole(requiredRoles) {
      return isSignedIn() &&
             (request.auth.token.role in requiredRoles);
    }

    // COMPANY MATCH
    function belongsToCompany(companyId) {
      return isSignedIn() &&
             request.auth.token.companyId == companyId;
    }

    // OWNERSHIP CHECK
    function isOwner(userId) {
      return isSignedIn() &&
             request.auth.uid == userId;
    }


    // ======================================================
    // GLOBAL USERS COLLECTION
    // ======================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ======================================================
    // Top-level collections for single-user mode (being phased out)
    // ======================================================
     match /invoices/{invoiceId} {
        allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
     }

    match /estimates/{estimateId} {
      allow get: if true; // Public read is allowed
      allow list, create, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /quotes/{quoteId} {
      allow get: if true; // Public read is allowed
      allow list, create, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }


    // ======================================================
    // COMPANY ROOT (strict multi-tenant isolation)
    // ======================================================
    match /companies/{companyId} {

      // ------------------------------
      // Company Document
      // ------------------------------
      allow read: if belongsToCompany(companyId);
      allow update: if belongsToCompany(companyId) && hasRole(["admin"]);

      // ------------------------------
      // Company Settings
      // ------------------------------
      match /settings/{settingsId} {
        allow read: if belongsToCompany(companyId);

        allow write: if belongsToCompany(companyId) &&
                      hasRole(["admin"]);
      }

      // ------------------------------
      // Company Users (employees)
      // ------------------------------
      match /users/{userId} {
        allow read: if belongsToCompany(companyId);

        allow create: if belongsToCompany(companyId) &&
                       hasRole(["admin"]);

        allow update: if belongsToCompany(companyId) &&
                       (isOwner(userId) || hasRole(["admin"]));

        allow delete: if belongsToCompany(companyId) &&
                       hasRole(["admin"]);
      }

      // ------------------------------
      // ROLES
      // ------------------------------
      match /roles/{roleId} {
        allow read: if belongsToCompany(companyId);
        allow write: if belongsToCompany(companyId) &&
                      hasRole(["admin"]);
      }

      // ------------------------------
      // INVOICES (COMPANY)
      // ------------------------------
      match /invoices/{invoiceId} {
        allow read: if belongsToCompany(companyId);

        allow create: if belongsToCompany(companyId) &&
                       hasRole(["admin", "staff"]);

        allow update: if belongsToCompany(companyId) &&
                       hasRole(["admin", "staff"]);

        allow delete: if belongsToCompany(companyId) &&
                       hasRole(["admin"]);
      }

      // ------------------------------
      // ESTIMATES (COMPANY)
      // ------------------------------
      match /estimates/{estimateId} {
        // Public read
        allow get: if true;

        allow list, create: if belongsToCompany(companyId) &&
                            hasRole(["admin", "staff"]);

        allow update, delete:
          if belongsToCompany(companyId) &&
             hasRole(["admin", "staff"]);
      }

      // ------------------------------
      // QUOTES (COMPANY)
      // ------------------------------
      match /quotes/{quoteId} {
        allow get: if true;

        allow list, create: if belongsToCompany(companyId) &&
                            hasRole(["admin", "staff"]);

        allow update, delete:
          if belongsToCompany(companyId) &&
             hasRole(["admin", "staff"]);
      }

      // ------------------------------
      // PRESETS (Reusable Line Item Groups)
      // ------------------------------
      match /presets/{presetId} {
        allow read: if belongsToCompany(companyId);

        allow write: if belongsToCompany(companyId) &&
                      hasRole(["admin", "staff"]);
      }
    }

    // ======================================================
    // MAIL trigger for sending PDF attachments
    // ======================================================
    match /mail/{docId} {
      allow create: if isSignedIn();
    }
  }
}
