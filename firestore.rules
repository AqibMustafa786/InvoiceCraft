
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user can read/write their own user document
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // A user can only access documents that have their userId
    match /invoices/{invoiceId} {
      // Allow owner to get, list, and delete their own documents.
      allow get, list, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Allow owner to create and update their own documents.
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // A user can only access estimates that have their userId
    match /estimates/{estimateId} {
      // Allow public read access to a single document for sharing.
      allow get: if true;
      // Allow owner to create, list, and delete their own documents.
      allow list, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // A user can only access quotes that have their userId
    match /quotes/{quoteId} {
      // Allow public read access to a single document for sharing.
      allow get: if true;
      // Allow owner to create, list, and delete their own documents.
      allow list, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Allow authenticated users to write to the 'mail' collection to trigger emails
    match /mail/{docId} {
      allow create: if isSignedIn();
    }
  }
}
