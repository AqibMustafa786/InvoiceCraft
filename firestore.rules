
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function getCompany(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data;
    }
    
    function belongsToCompany(companyId) {
       return isSignedIn() && getUser(request.auth.uid).companyId == companyId;
    }
    
    function hasCompanyRole(companyId, requiredRoles) {
        return belongsToCompany(companyId) && getUser(request.auth.uid).role in requiredRoles;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // USER-SPECIFIC DATA
    match /users/{userId} {
      allow read, update, delete: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn();
    }

    // COMPANY DATA
    match /companies/{companyId} {
      allow get: if belongsToCompany(companyId);
      allow list: if false; // Don't allow listing all companies
      allow create: if isSignedIn(); // User can create their own company
      allow update: if hasCompanyRole(companyId, ['admin']);

      // Nested collections within a company
      match /invoices/{invoiceId} {
          allow read, update, delete: if belongsToCompany(companyId);
          allow create: if belongsToCompany(companyId);
      }
      
      match /quotes/{quoteId} {
          allow get: if true; // Publicly readable for sharing
          allow list, create, update, delete: if belongsToCompany(companyId);
      }

      match /estimates/{estimateId} {
          allow read: if resource.data.isPublic == true || belongsToCompany(companyId);
          allow list, create, update, delete: if belongsToCompany(companyId);
      }
      
      // Tighter rules for user management within a company
      match /users/{userId} {
        allow read: if belongsToCompany(companyId);
        allow create: if hasCompanyRole(companyId, ['admin']);
        allow update: if hasCompanyRole(companyId, ['admin']) || (isOwner(userId) && belongsToCompany(companyId));
        allow delete: if hasCompanyRole(companyId, ['admin']);
      }
      
      // Client Management
      match /clients/{clientId} {
        allow read, list, create, update, delete: if belongsToCompany(companyId);
      }

      // General fallback for other collections
       match /{collection}/{docId} {
        allow read: if belongsToCompany(companyId);
        allow create, update: if hasCompanyRole(companyId, ['admin', 'staff']);
        allow delete: if hasCompanyRole(companyId, ['admin']);
      }
    }
    
    // MAIL trigger for sending emails
    match /mail/{docId} {
      allow create: if isSignedIn();
    }
  }
}
