
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn(){ return request.auth != null; }
    function isOwner(userId){ return isSignedIn() && request.auth.uid == userId; }

    match /estimates/{estimateId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read, delete: if isOwner(resource.data.userId);
      
      // Allow a client to accept/decline (update status and signature)
      // They cannot change any other field.
      allow update: if (isOwner(resource.data.userId)) || 
                       (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'clientSignature', 'auditLog']));

       // Allow public read if the document is marked as public
      allow get: if resource.data.isPublic == true; 
    }
    
    match /quotes/{quoteId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read, delete: if isOwner(resource.data.userId);
      
       // Allow a client to accept/decline (update status and signature)
      allow update: if (isOwner(resource.data.userId)) || 
                       (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'clientSignature', 'auditLog']));

       // Allow public read if the document is marked as public
      allow get: if resource.data.isPublic == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /invoices/{invoiceId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read, update, delete: if isOwner(resource.data.userId);
    }
  }
}
