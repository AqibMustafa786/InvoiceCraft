rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Grant access if the user is the owner of the document
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    // Rules for the 'invoices' collection
    match /invoices/{invoiceId} {
        // Allow create if the user is signed in and the new document's userId matches their UID
        allow create: if isSignedIn() && isOwner(request.resource.data.userId);

        // Allow read, update, delete if the user is signed in and owns the document
        allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // Rules for the 'quotes' collection
    match /quotes/{quoteId} {
        // Allow create if the user is signed in and the new document's userId matches their UID
        allow create: if isSignedIn() && isOwner(request.resource.data.userId);

        // Allow read, update, delete if the user is signed in and owns the document
        allow read, update: if isSignedIn() && isOwner(resource.data.userId);
        
        // Public read access for shared links
        allow get: if true; 
    }
    
    // Allow a user to list documents from a collection if they are querying by their own userId
    match /{path=**}/invoices/{invoiceId} {
        allow list: if isSignedIn() && request.query.where.userId == request.auth.uid;
    }
     match /{path=**}/quotes/{quoteId} {
        allow list: if isSignedIn() && request.query.where.userId == request.auth.uid;
    }
  }
}
