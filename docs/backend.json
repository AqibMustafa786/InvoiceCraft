
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the InvoiceCraft application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Company. (Relationship: Company 1:N User)"
        }
      },
      "required": [
        "id",
        "email",
        "companyId"
      ]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a company that uses the InvoiceCraft application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Company entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the company."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the company logo.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice document.",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "clientName": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] }
      },
      "required": ["id", "companyName", "clientName", "invoiceDate", "totalAmount", "status"]
    },
    "Estimate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Estimate",
      "type": "object",
      "description": "Represents a quote or estimate generated by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Estimate entity."
        },
        "userId": {
            "type": "string"
        },
        "estimateNumber": {
            "type": "string"
        },
        "estimateDate": {
            "type": "string",
            "format": "date-time"
        },
        "validUntilDate": {
            "type": "string",
            "format": "date-time"
        },
        "status": {
            "type": "string", "enum": ["draft", "sent", "accepted", "rejected", "expired"]
        },
        "business": {
            "type": "object",
            "properties": {
                "name": {"type": "string"},
                "address": {"type": "string"},
                "phone": {"type": "string"},
                "email": {"type": "string"},
                "website": {"type": "string"},
                "licenseNumber": {"type": "string"},
                "logoUrl": {"type": "string"}
            }
        },
        "client": {
            "type": "object",
            "properties": {
                 "name": {"type": "string"},
                 "companyName": {"type": "string"},
                 "address": {"type": "string"},
                 "phone": {"type": "string"},
                 "email": {"type": "string"}
            }
        },
        "summary": {
            "type": "object",
            "properties": {
                "subtotal": {"type": "number"},
                "taxPercentage": {"type": "number"},
                "taxAmount": {"type": "number"},
                "discount": {"type": "number"},
                "grandTotal": {"type": "number"},
                "shippingCost": {"type": "number"}
            }
        },
        "projectTitle": {"type": "string"},
        "referenceNumber": {"type": "string"},
        "termsAndConditions": {"type": "string"}
      },
      "required": [
        "id",
        "userId",
        "estimateNumber",
        "estimateDate",
        "business",
        "client",
        "lineItems",
        "summary"
      ]
    },
    "LineItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LineItem",
      "type": "object",
      "description": "Represents an item within a quote or invoice.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the LineItem entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the item."
        },
        "description": {
            "type": "string"
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the item."
        },
        "unitPrice": {
          "type": "number",
          "description": "Price of a single unit of the item."
        }
      },
      "required": [
        "id",
        "name",
        "quantity",
        "unitPrice"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": {
            "$ref": "#/backend/entities/Company"
          },
          "description": "Stores company information.  Root-level collection for multi-tenancy.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user information, scoped to a company. Requires companyId to match the parent company document.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "userId",
              "description": "Unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": {
            "$ref": "#/backend/entities/Invoice"
          },
          "description": "Stores invoice documents for a company.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "invoiceId",
              "description": "Unique identifier for the invoice."
            }
          ]
        }
      },
      {
        "path": "estimates/{estimateId}",
        "definition": {
          "entityName": "Estimate",
          "schema": {
            "$ref": "#/backend/entities/Estimate"
          },
          "description": "Stores estimate information. Each estimate belongs to a user.",
          "params": [
            {
              "name": "estimateId",
              "description": "Unique identifier for the estimate."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to support a multi-tenant SaaS invoice generator (InvoiceCraft) with a focus on security, scalability, and debuggability. The structure leverages path-based ownership for user-specific data and denormalization to ensure authorization independence. The top-level collections segregate company and user data, with subcollections for estimates and line items, ensuring clear ownership and simplified security rules.\n\nAuthorization Independence is achieved through path-based ownership. Estimates and line items are stored under the company and user paths, so `get()` calls are avoided. This strategy, combined with structural segregation, ensures that list operations are secure, as rules can be applied based on path ownership. For example, only users belonging to a specific company can list estimates under that company's path.  This segregation also supports QAPs, as list operations are scoped to a user's own data or data they have explicit access to via company membership."
  }
}
