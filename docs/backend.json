
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the InvoiceCraft application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Company. (Relationship: Company 1:N User)"
        }
      },
      "required": [
        "id",
        "email",
        "companyId"
      ]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a company that uses the InvoiceCraft application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Company entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the company."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the company logo.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice document.",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "clientName": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] }
      },
      "required": ["id", "companyName", "clientName", "invoiceDate", "totalAmount", "status"]
    },
    "Quote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quote",
      "type": "object",
      "description": "Represents a quote generated by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Quote entity."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Company. (Relationship: Company 1:N Quote)"
        },
        "clientName": {
          "type": "string",
          "description": "Name of the client the quote is for."
        },
        "clientAddress": {
          "type": "string",
          "description": "Address of the client."
        },
        "quoteDate": {
          "type": "string",
          "description": "Date the quote was created.",
          "format": "date-time"
        },
        "taxRate": {
          "type": "number",
          "description": "Tax rate applied to the quote."
        },
        "discountRate": {
          "type": "number",
          "description": "Discount rate applied to the quote."
        },
        "subtotal": {
          "type": "number",
          "description": "Subtotal of the quote before tax and discount."
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount of the quote after tax and discount."
        },
        "termsAndConditions": {
          "type": "string",
          "description": "Terms and conditions of the quote."
        },
        "optionalAttachments": {
          "type": "string",
          "description": "Link to optional attachments"
        },
        "status": {
          "type": "string",
          "description": "Status of the quote"
        }
      },
      "required": [
        "id",
        "companyId",
        "clientName",
        "clientAddress",
        "quoteDate",
        "subtotal",
        "totalAmount"
      ]
    },
    "QuoteItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuoteItem",
      "type": "object",
      "description": "Represents an item within a quote.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the QuoteItem entity."
        },
        "quoteId": {
          "type": "string",
          "description": "Reference to the Quote. (Relationship: Quote 1:N QuoteItem)"
        },
        "name": {
          "type": "string",
          "description": "Name of the item."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the item."
        },
        "rate": {
          "type": "number",
          "description": "Rate of the item."
        },
        "subtotal": {
          "type": "number",
          "description": "Subtotal for the individual item (quantity * rate)."
        }
      },
      "required": [
        "id",
        "quoteId",
        "name",
        "quantity",
        "rate",
        "subtotal"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": {
            "$ref": "#/backend/entities/Company"
          },
          "description": "Stores company information.  Root-level collection for multi-tenancy.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user information, scoped to a company. Requires companyId to match the parent company document.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "userId",
              "description": "Unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": {
            "$ref": "#/backend/entities/Invoice"
          },
          "description": "Stores invoice documents for a company.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "invoiceId",
              "description": "Unique identifier for the invoice."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/quotes/{quoteId}",
        "definition": {
          "entityName": "Quote",
          "schema": {
            "$ref": "#/backend/entities/Quote"
          },
          "description": "Stores quote information. Each quote belongs to a company.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "quoteId",
              "description": "Unique identifier for the quote."
            }
          ]
        }
      },
      {
        "path": "companies/{companyId}/quotes/{quoteId}/items/{quoteItemId}",
        "definition": {
          "entityName": "QuoteItem",
          "schema": {
            "$ref": "#/backend/entities/QuoteItem"
          },
          "description": "Stores individual items within a quote.  Scoped under the quote document.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            },
            {
              "name": "quoteId",
              "description": "Unique identifier for the quote."
            },
            {
              "name": "quoteItemId",
              "description": "Unique identifier for the quote item."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to support a multi-tenant SaaS invoice generator (InvoiceCraft) with a focus on security, scalability, and debuggability. The structure leverages path-based ownership for user-specific data and denormalization to ensure authorization independence. The top-level collections segregate company and user data, with subcollections for quotes and quote items, ensuring clear ownership and simplified security rules.\n\nAuthorization Independence is achieved through path-based ownership. Quotes and quote items are stored under the company and user paths, so `get()` calls are avoided. This strategy, combined with structural segregation, ensures that list operations are secure, as rules can be applied based on path ownership. For example, only users belonging to a specific company can list quotes under that company's path.  This segregation also supports QAPs, as list operations are scoped to a user's own data or data they have explicit access to via company membership."
  }
}
